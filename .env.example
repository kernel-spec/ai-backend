# Lokální vývoj: zkopíruj tento soubor jako .dev.vars (pro wrangler dev)
# Produkční secrets nastavuj přes: wrangler secret put <NÁZEV>
# NIKDY necommituj skutečné hodnoty do gitu.

# OpenAI API klíč — získáš na https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Cloudflare API token — používá se pouze v CI/CD (GitHub Secret), ne lokálně
# Získáš na https://dash.cloudflare.com/profile/api-tokens (šablona "Edit Cloudflare Workers")
CLOUDFLARE_API_TOKEN=
